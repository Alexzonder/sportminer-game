<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>SportMiner</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #111; color: #e0e0e0; margin: 0; padding: 40px; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .container { background: rgba(25, 25, 25, 0.9); padding: 35px; border-radius: 15px; box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5); max-width: 480px; width: 100%; position: relative; }
        h1 { text-align: center; color: #00e676; margin-bottom: 25px; font-size: 28px; }
        
        /* Стиль для кнопки "Начать!" */
        .btn-start { background-color: #ff9800; color: white; border: none; padding: 16px; font-size: 18px; cursor: pointer; border-radius: 30px; display: block; width: calc(100% - 32px); margin-left: auto; margin-right: auto; margin-top: 25px; }
        
        /* Стиль для кнопок видов спорта */
        .answer-btn { display: block; width: 100%; padding: 14px; margin-bottom: 12px; border: none; border-radius: 10px; background-color: #2a2a2a; color: white; font-size: 17px; cursor: pointer; transition: all 0.2s ease-in-out; }
        .answer-btn:hover { background-color: #444; }

        /* Стиль для блока матча */
        .match { background: rgba(30, 30, 30, 0.85); margin-bottom: 25px; padding: 20px; border-radius: 12px; border-left: 4px solid #00e676; cursor: pointer;}

        /* Стиль для блока "ЗДЕСЬ ПУСТО" */
        .empty-match { background: rgba(30, 30, 30, 0.85); margin-bottom: 25px; padding: 20px; border-radius: 12px; border-left: 4px solid #ff9800; color:#aaa;}

        /* Номер страницы */
        #page-number {
            position: absolute;
            top: 15px;
            left: 15px;
            color: #fff;
            font-size: 18px;
            font-weight: bold;
            opacity: 0.5;
        }

        /* Зеленый пунктир (результат ставки) */
        #result { 
            margin-top: 25px;
            padding-top: 18px;
            border-top: 2px dashed rgba(0, 230, 118, 0.4); 
            font-size: 20px;
            text-align: center;
            min-height: 40px;
        }

        /* ИСПРАВЛЕНИЕ ВИЗУАЛЬНОГО БАГА */
        #bet-screen {
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>

<div class="container">
    <!-- НОМЕР СТРАНИЦЫ -->
    <div id="page-number">1</div> 

    <h1>SportMiner</h1>

    <!-- БЛОК МАТЧЕЙ (Страница списка) - НАЧИНАЕТ СКРЫТЫМ -->
    <div id="matches-container" class="match" style="display:none;"> 
        <p class="question">Сегодняшние матчи РПЛ:</p>
        
        <!-- МАТЧ 1 (Страница списка) -->
        <div id="match-1" class="match" onclick="goToMatchPage('match-1')">
            <p><strong>4.1</strong> <strong>Пари НН</strong> vs <strong>Ростов</strong></p>
            <p style="color:#aaa;">Начало матча в 14:00</p>
        </div>

        <!-- МАТЧ 2 (Страница списка) -->
        <div id="match-2" class="match" onclick="goToMatchPage('match-2')">
            <p><strong>4.2</strong> <strong>Динамо Махачкала</strong> vs <strong>Балтика</strong></p>
            <p style="color:#aaa;">Начало матча в 16:30</p>
        </div>

         <!-- МАТЧ 3 (Страница списка) -->
        <div id="match-3" class="match" onclick="goToMatchPage('match-3')">
            <p><strong>4.3</strong> <strong>Спартак</strong> vs <strong>Локомотив</strong></p>
            <p style="color:#aaa;">Начало матча в 19:30</p>
        </div>
    </div>

    <!-- БЛОК СТАВКИ НА КОНКРЕТНЫЙ МАТЧ (Страница ставки) - НАЧИНАЕТ СКРЫТЫМ -->
    <div id="bet-screen" class="match" style="display:none;">
        <!-- Здесь будет информация о матче и кнопки ставок -->
        <h2 id="bet-match-title"></h2>
        <p id="bet-match-time" style="color:#aaa;"></p>
        
        <p class="question">Кто победит?</p>
        
        <button class="answer-btn" onclick="makeBet('current', 'home')">Победа хозяев</button>
        <button class="answer-btn" onclick="makeBet('current', 'draw')">Ничья</button>
        <button class="answer-btn" onclick="makeBet('current', 'away')">Победа гостей</button>
        
        <!-- Зеленый пунктир для результата ставки -->
        <div id="result"></div>
        
        <button class="btn-start" style="margin-top:25px;" onclick="goBackToMatches()">Назад к матчам</button>
    </div>

    <!-- БЛОК ЗАГОГУЛКИ (Страница 3) - НАЧИНАЕТ СКРЫТЫМ -->
    <div id="match-empty" class="empty-match" style="display:none;"> 
        <p style="color:#aaa;">ЗДЕСЬ ПОКА ПУСТО</p>
        <p style="color:#aaa;">Данная дисциплина находится в разработке.</p>
        <button class="btn-start" onclick="goBackToSelection()">НАЗАД</button>
        <button class="btn-start" style="margin-top:15px;" onclick="goToMain()">НА ГЛАВНУЮ</button>
    </div>

    <!-- БЛОК ВЫБОРА СПОРТА (Страница 2) - НАЧИНАЕТ СКРЫТЫМ -->
    <div id="sport-selection" class="match" style="display:none;"> 
        <p class="question">Выбери дисциплину:</p>
        
         <!-- Кнопка Футбол теперь активна и ведет на Страницу со списком матчей -->
        <button class="answer-btn" onclick="showMatchesPage()">Футбол</button>
        
        <!-- Эти кнопки ведут на Страницу 3 (Заглушка) -->
        <button class="answer-btn" onclick="showEmptyPage()">Хоккей</button>
        <button class="answer-btn" onclick="showEmptyPage()">Баскетбол</button>
        <button class="answer-btn" onclick="showEmptyPage()">Киберспорт</button>
    </div>

    <!-- БЛОК ОНБОРДИНГА (Страница 1) - НАЧИНАЕТ ВИДИМЫМ -->
    <div id="onboarding-div" style="text-align:center; margin-bottom:30px;"> 
        <h1>СПОРТКОИН</h1>
        <p>Проект СПОРТМАЙНЕР приветствует тебя!</p>
        <p>Здесь твои знания спорта превращаются в монеты.</p>
        <button class="btn-start" id="start-btn">Начать!</button> 
    </div>

</div>

<script>
// --- НАЧАЛО ЛОГИКИ --
let balance = parseFloat(1399.2);
let currentMatchId = '';

// Переход со Страницы 1 на Страницу 2
document.getElementById('start-btn').addEventListener('click', function() {
    document.getElementById('onboarding-div').style.display = 'none';
    document.getElementById('sport-selection').style.display = 'block';
    document.getElementById('page-number').textContent = '2';
});

// Переход на Страницу 3 (Заглушка)
function showEmptyPage() {
    document.getElementById('sport-selection').style.display = 'none';
    document.getElementById('match-empty').style.display = 'block';
    document.getElementById('page-number').textContent = '3';
}

// Кнопка "НАЗАД" на Странице 3
function goBackToSelection() {
    document.getElementById('match-empty').style.display = 'none';
    document.getElementById('sport-selection').style.display = 'block';
    document.getElementById('page-number').textContent = '2';
}

// Кнопка "НА ГЛАВНУЮ" на Странице 3
function goToMain() {
    document.getElementById('match-empty').style.display = 'none';
    document.getElementById('onboarding-div').style.display = 'block';
    document.getElementById('page-number').textContent = '1';
}


// --- НОВАЯ ЛОГИКА ДЛЯ СТРАНИЦЫ МАТЧЕЙ (СПИСОК) ---

// Функция для загрузки и отображения матчей из JSON
async function showMatchesPage() {
    document.getElementById('sport-selection').style.display = 'none';
    
    const container = document.getElementById('matches-container');
    container.innerHTML = ''; // Очищаем контейнер на случай повторных заходов
    container.style.display = 'block';

    try {
        // 1. Загружаем файл JSON
        const response = await fetch('matches.json'); 
        const matches = await response.json(); // Преобразуем ответ в объект JavaScript

        // 2. Добавляем заголовок списка
        const title = document.createElement('p');
        title.className = 'question';
        title.textContent = 'Сегодняшние матчи РПЛ:';
        container.appendChild(title);

        // 3. Проходим по каждому матчу из файла
        matches.forEach(match => {
            // Создаем блок для каждого матча ДИНАМИЧЕСКИ
            const matchDiv = document.createElement('div');
            matchDiv.id = match.id; // Например, 'match-1'
            matchDiv.className = 'match';
            matchDiv.onclick = () => goToMatchPage(match.id);
            
            // Формируем текстовое содержимое блока из данных JSON
            matchDiv.innerHTML = `
                <p><strong>${match.number}</strong> <strong>${match.home}</strong> vs <strong>${match.away}</strong></p>
                <p style="color:#aaa;">Начало матча в ${match.time}</p>
            `;
            
            // Добавляем созданный блок на страницу
            container.appendChild(matchDiv);
        });
        
        // 4. Показываем баланс (как и раньше)
        let balanceDiv = document.createElement('div');
        balanceDiv.className = 'balance';
        balanceDiv.textContent = `Баланс: ${balance.toFixed(1)} СПОРТКОИН`;
        
        let containerRef = document.getElementById('matches-container');
        containerRef.insertBefore(balanceDiv, containerRef.firstChild.nextSibling); 

        document.getElementById('page-number').textContent = '4';

    } catch (error) {
        console.error("Ошибка при загрузке матчей:", error);
        container.innerHTML = '<p style="color:red;">Не удалось загрузить список матчей.</p>';
    }
}


// Функция для перехода на страницу ставки (Страница ставки)
function goToMatchPage(matchId) {
    // Скрываем список матчей
    document.getElementById('matches-container').style.display = 'none';
    
    // Показываем экран ставки
    document.getElementById('bet-screen').style.display = 'block';
    
    // Запоминаем, какой матч выбран
    currentMatchId = matchId;
    
     // --- ИСПРАВЛЕННЫЙ БЛОК ---
    // Получаем все параграфы внутри выбранного матча (НАДЁЖНЫЙ СПОСОБ)
    const paragraphs = document.getElementById(matchId).getElementsByTagName('p');
    
    // Первый параграф - это название и номер матча
    const matchTitle = paragraphs[0].textContent;
    
    // Второй параграф - это время матча
    const matchTime = paragraphs[1].textContent;
    
    document.getElementById('bet-match-title').textContent = matchTitle;
    document.getElementById('bet-match-time').textContent = matchTime;
    
    // Обновляем номер страницы
    const matchNumber = matchId.replace('match-', '');
    document.getElementById('page-number').textContent = `4.${matchNumber}`;
}

// Кнопка "Назад к матчам" на Странице ставки
function goBackToMatches() {
    document.getElementById('bet-screen').style.display = 'none';
    document.getElementById('matches-container').style.display = 'block';
    document.getElementById('page-number').textContent = '4';
}


// --- ФУНКЦИЯ СТАВКИ ---
function makeBet(dummyMatchId, betType) {
    const COST = 0.1;
     if (balance < COST) {
         alert("Недостаточно СПОРТКОИН для ставки!");
         return;
     }
     balance -= COST;
     
     const resultIndex = Math.floor(Math.random() * 3); // Генерируем результат

     const isWin = (
         (betType === 'home' && resultIndex === 0) ||
         (betType === 'draw' && resultIndex === 1) ||
         (betType === 'away' && resultIndex === 2)
     );
     
     const resultDiv = document.getElementById('result');
     
     if (isWin) {
         let POOL = Math.floor(Math.random() * (150 - 50 + 1)) + 50;
         balance += POOL;
         resultDiv.innerHTML = `<p class=\"win\">🎉 Поздравляем! Вы угадали! Награда +${POOL} СПОРТКОИН.</p>`;
     } else {
         resultDiv.innerHTML = `<p class=\"lose\">😞 Не угадали. Комиссия сожжена.</p>`;
     }
     
     // --- ИСПРАВЛЕНИЕ КРИТИЧЕСКОЙ ОШИБКИ ---
     // Ищем элемент баланса НА СТРАНИЦЕ СТАВКИ и обновляем его напрямую из переменной
     const balanceDisplayOnBetScreen = document.getElementById('bet-screen').querySelector('.balance');
     if(balanceDisplayOnBetScreen) {
         balanceDisplayOnBetScreen.textContent = `Баланс: ${balance.toFixed(1)} СПОРТКОИН`;
     }
     
     setTimeout(() => {
         resultDiv.innerHTML = '';
     }, 2000);
}

</script>

</body>
</html>